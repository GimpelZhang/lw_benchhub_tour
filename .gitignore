# =============================================================================
# .gitignore for lw_benchhub_tour
# Aggregated monorepo of the LW-BenchHub + IsaacLab-Arena + lerobot VLA pipeline.
# =============================================================================

# ---- Secrets / env shims (NEVER commit; .example templates are tracked) ----
headless_env.sh
llm_env.sh
deepseek_v4pro_env.sh
*.env.sh
!*.env.sh.example
!headless_env.sh.example
!llm_env.sh.example
!deepseek_v4pro_env.sh.example

# ---- Large model weights / conda env / HF cache ----
models/
conda/
.cache/

# ---- Datasets (too large; see docs/Complete_Stage_*.md for download/generation) ----
stage4_flywheel/datasets/
eval_outputs_*/

# ---- docs/ : consolidated markdown reference (kept on disk, NOT committed per project spec) ----
docs/

# ---- Logs / install logs / pid files ----
# Note: pathB_logs*/ dirs contain BOTH .log/.pid/.stdout (ignore) AND .sh launch
# scripts (KEEP - they are source). So we do NOT exclude the dirs wholesale; we
# exclude only the log/pid/stdout/json extensions + the v1-v5 historical log trees.
*.log
*.pid
*.stdout
# Local safety backups created by Stage4 Phase 2 / Patch 02 (restore points, not source)
*.bak_patch01
*.bak_patch01_descend
*.bak_patch02
pathB_headcam_logs/
autosim_install_logs/
v5_install_logs/
v6_install_logs/
stage3_logs/
stage4_flywheel/logs/
# historical stage2 v1-v5 log+manifest trees (canonical is v6; keep v6 .sh scripts + manifest)
pathB_logs_v2/
pathB_logs_v3/
pathB_logs_v4/
pathB_logs_v5/
# in pathB_logs/ and stage2_logs/, ignore everything except .sh + key manifests
# (stage2_logs/ was renamed from pathB_logs_v6/ when _v6 suffixes were removed)
pathB_logs/*
!pathB_logs/run_pathB.sh
!pathB_logs/run_stage2*.sh
stage2_logs/*
!stage2_logs/run_stage2_all.sh
!stage2_logs/run_stage2_scene.sh
!stage2_logs/final_manifest.json
!stage2_logs/smoketest.json
!stage2_logs/scene_reach_reports/

# ---- Python caches / build artifacts ----
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
*.so

# ---- OMC orchestrator state (session-local, not source) ----
.omc/

# ---- Legacy / archived superseded code (kept on disk, not in repo) ----
_legacy/
_git_backups/

# ---- Temp planning scratch dirs ----
.tmp_stage3_plan*/
.tmp_stage3_plan/

# ---- Editor / OS cruft ----
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# ---- Nested-repo leftover .git dirs after absorb (safety; should not exist) ----
*/.git/
*/*/.git/

# ---- Misc binary outputs ----
*.mp4
*.hdf5
*.h5
*.tar.gz
!_git_backups/*.tar.gz

# ---- Regression test run outputs (regenerable) ----
regress_stage2_live/
regress_stage4_live/
eval_outputs_smoke_regress/

# ---- Stage 2 final deliverables (regenerated by verify_stage2.py; .png snapshots cleaned) ----
stage2_final_deliverables/

# ---- v-strip rename regression outputs (regenerable, not source) ----
regress_vstrip_stage1/
regress_vstrip_stage2/
regress_vstrip_stage4/
# legacy on-disk dir name from before rename (runtime output, gitignored)
stage2_v6_final_deliverables/

tmp/
genesis_vla_env.sh
